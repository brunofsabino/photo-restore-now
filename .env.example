# ===========================================
# GENERAL
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# STRIPE PAYMENT (US Market)
# ===========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# AI RESTORATION PROVIDERS
# ===========================================

# *** RECOMMENDED *** Replicate (GFPGAN + Real-ESRGAN + DeOldify pipeline)
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# Legacy providers (kept for reference — not recommended for production)
# VanceAI API
VANCEAI_API_KEY=your_vanceai_api_key_here
VANCEAI_API_URL=https://api-service.vanceai.com

# Hotpot AI API
HOTPOT_API_KEY=your_hotpot_api_key_here
HOTPOT_API_URL=https://api.hotpot.ai

# Active Provider: "replicate" | "vanceai" | "hotpot" | "fake"
AI_PROVIDER=replicate

# ===========================================
# AUTH (NextAuth)
# ===========================================
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# ===========================================
# EMAIL SERVICE (Resend)
# ===========================================
RESEND_API_KEY=re_your_resend_api_key_here
# Sender address — must be verified in Resend dashboard
RESEND_FROM_EMAIL=support@yourdomain.com
# Support contact shown in emails and UI (can be same as RESEND_FROM_EMAIL)
SUPPORT_EMAIL=support@yourdomain.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# ===========================================
# ANALYTICS & MONITORING
# ===========================================

# Mixpanel Analytics
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_project_token
MIXPANEL_TOKEN=your_mixpanel_project_token

# Admin Emails (comma-separated for error alerts)
ADMIN_EMAILS=admin@photorestorenow.com,tech@photorestorenow.com

# ===========================================
# STORAGE
# ===========================================

# Cloudflare R2 (Recommended - FREE 10GB + unlimited egress)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=photo-restore-now
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# AWS S3 (Alternative - costs apply)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=photo-restore-now

# Set to "true" to use R2 in development (defaults to local storage)
USE_R2=false

# ===========================================
# BACKGROUND JOBS (Inngest)
# ===========================================
# Leave blank in development (uses local Inngest dev server)
# Get from: https://app.inngest.com → your app → API keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Note: If R2 is not configured, will fallback to local storage (development only)

# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection string
# Development: Use local PostgreSQL via Docker
# Production: Use Neon (FREE tier) or Supabase
DATABASE_URL=postgresql://photorestore:photorestore_dev@localhost:5432/photorestore

# Neon (Recommended for production - FREE tier: 512MB)
# DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/photorestore?sslmode=require

# Supabase (Alternative - FREE tier: 500MB)
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ===========================================
# SECURITY
# ===========================================
# Maximum file size for uploads (in bytes) - 10MB
MAX_FILE_SIZE=10485760

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/webp

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60000
# ===========================================
# TESTING / DEVELOPMENT
# ===========================================
# Enable test mode to bypass payment and use mock payment flow
# Set to "true" for Phase 2 testing (upload → restore → email without Stripe)
TEST_MODE=true